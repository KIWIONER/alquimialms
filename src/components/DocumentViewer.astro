---
interface Props {
    title: string;
    currentLeccion: string;
    totalLecciones: number;
}

const { title, currentLeccion, totalLecciones } = Astro.props;
---

<div class="flex flex-col h-full bg-white shadow-sm border border-slate-200 m-6 rounded-xl overflow-hidden">
    <!-- Viewer Tools -->
    <div class="h-12 bg-slate-50 border-b border-slate-200 flex items-center px-4 justify-between shrink-0">
        <div class="flex items-center gap-4">
            <span class="text-xs font-bold text-slate-500 uppercase tracking-tighter">Visor de Documentos</span>
            <div class="h-4 w-px bg-slate-300"></div>
            <h3 class="text-sm font-semibold text-slate-800">{title}</h3>
        </div>
        
        <div class="flex items-center gap-2">
            <button class="p-1.5 hover:bg-slate-200 rounded-md transition-colors text-slate-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
                </svg>
            </button>
            <button class="p-1.5 hover:bg-slate-200 rounded-md transition-colors text-slate-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
            </button>
        </div>
    </div>

    <!-- The "Robust" Viewer Area -->
    <div class="flex-1 bg-slate-800 relative overflow-hidden flex items-center justify-center">
        <!-- Placeholder for the actual PDF iframe/canvas -->
        <div class="w-full max-w-4xl aspect-[1/1.41] bg-white shadow-2xl relative">
            <!-- Simulated PDF Content -->
            <div class="p-16 space-y-6">
                <!-- Medical Header -->
                <div class="flex justify-between items-start border-b-2 border-medical-green-500 pb-4">
                    <div>
                        <h1 class="text-2xl font-bold text-slate-900 leading-tight">UD04: Bioquímica de los Macronutrientes</h1>
                        <p class="text-sm text-slate-500 font-medium">Grado Superior en Dietética - Nutrición Humana</p>
                    </div>
                    <div class="text-right">
                        <span class="text-xs font-bold text-medical-green-600">ALQUIMIA ACADEMY</span>
                        <p class="text-[10px] text-slate-400">2026 Edition</p>
                    </div>
                </div>

                <!-- Simulated Text Blocks -->
                <div class="space-y-4 pt-4">
                    <h2 class="text-xl font-bold text-medical-green-800">1.2. Transmutación Metabólica de Hidratos de Carbono</h2>
                    <p class="text-slate-700 leading-relaxed text-sm">
                        La digestión de los hidratos de carbono comienza en la boca con la acción de la amilasa salival, que inicia la hidrólisis de los enlaces glucosídicos del almidón. Este proceso continúa en el intestino delgado mediante la acción coordinada de enzimas pancreáticas y del borde en cepillo...
                    </p>
                    <div class="bg-medical-green-50 p-4 border-l-4 border-medical-green-500 italic text-sm text-medical-green-900">
                        "El metabolismo energético no es solo una combustión química; es la base de la vitalidad que estudiamos en nuestra Alquimia moderna."
                    </div>
                    <p class="text-slate-700 leading-relaxed text-sm">
                        La glucosa obtenida es transportada al hígado a través de la vena porta, donde puede ser almacenada como glucógeno o liberada al torrente sanguíneo para su utilización celular inmediata.
                    </p>
                    <!-- Simulated Diagram -->
                    <div class="w-full h-48 bg-slate-50 border border-slate-200 rounded-lg flex items-center justify-center">
                        <span class="text-xs text-slate-400 font-bold uppercase tracking-widest">[Esquema de la Glucólisis]</span>
                    </div>
                </div>
            </div>
            
            <!-- Floating Navigation Overlay -->
            <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex items-center gap-4 bg-white/90 backdrop-blur shadow-lg border border-slate-200 px-6 py-2 rounded-full">
                <button class="text-slate-400 hover:text-medical-green-600 disabled:opacity-30">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </button>
                <span class="text-sm font-bold text-slate-700">Página 14 de 124</span>
                <button class="text-medical-green-600 hover:text-medical-green-800">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <!-- Navigation Footer -->
    <div class="h-14 bg-white border-t border-slate-200 flex items-center px-6 justify-between shrink-0">
        <div class="flex items-center gap-2">
            <span class="text-[10px] font-bold text-slate-400 uppercase">Lección {currentLeccion} de {totalLecciones}</span>
            <div class="w-24 h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-medical-green-500" style="width: 30%;"></div>
            </div>
        </div>
        
        <div class="flex items-center gap-3">
            <button class="text-xs font-bold text-slate-500 hover:text-slate-800 transition-colors uppercase">Anterior</button>
            <button class="btn-medical text-xs uppercase tracking-widest px-6 !py-1.5">Siguiente Lección</button>
        </div>
    </div>
</div>
